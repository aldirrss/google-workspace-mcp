# ─── OAuth2 Client Secret ─────────────────────────────────────────────────────
# Download from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
#
# Option A: Paste the full client_secret.json content as a single-line string
GOOGLE_OAUTH_CLIENT_SECRET_JSON='{"web":{"client_id":"...","client_secret":"...","redirect_uris":["https://your-domain.com/auth/callback"],...}}'

# Option B: Path to the client_secret.json file mounted into the container
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/secrets/client_secret.json

# ─── OAuth2 Token Storage ─────────────────────────────────────────────────────
# Path where the OAuth2 token is saved after first authorization.
# Must be inside the mounted ./secret volume so it persists across container restarts.
GOOGLE_TOKEN_FILE=/secrets/token.json

# ─── OAuth2 Callback URL ──────────────────────────────────────────────────────
# Public base URL of this server — used to build the OAuth2 redirect URI.
# Must exactly match one of the "Authorized redirect URIs" in Google Cloud Console.
# Add: https://your-domain.com/auth/callback
SERVER_BASE_URL=https://your-domain.com

# ─── Server (HTTP transport only) ─────────────────────────────────────────────
SERVER_PORT=8347
SERVER_HOST=0.0.0.0

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
