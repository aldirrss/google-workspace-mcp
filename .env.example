# ─── OAuth2 Client Secret ─────────────────────────────────────────────────────
# Download from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Type: Web Application
# Add authorized redirect URI: https://your-domain.com/google/callback
#
# Option A: Paste the full client_secret.json content as a single-line string
GOOGLE_OAUTH_CLIENT_SECRET_JSON='{"web":{"client_id":"...","client_secret":"...","redirect_uris":["https://your-domain.com/google/callback"],...}}'

# Option B: Path to the client_secret.json file mounted into the container
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/secrets/client_secret.json

# ─── Server Base URL ──────────────────────────────────────────────────────────
# Public HTTPS URL of this server — used to build OAuth2 redirect URIs and MCP
# metadata endpoints. Must match your domain exactly (no trailing slash).
SERVER_BASE_URL=https://your-domain.com

# ─── Server (HTTP transport only) ─────────────────────────────────────────────
SERVER_PORT=8347
SERVER_HOST=0.0.0.0

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
