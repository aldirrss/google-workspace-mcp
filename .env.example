# ─── OAuth2 Client Secret ─────────────────────────────────────────────────────
# Choose one option — either inline JSON (A) or a file path (B).
#
# Download from: Google Cloud Console → APIs & Services → Credentials
#   → OAuth 2.0 Client IDs → Download JSON (Web Application type)
#
# Option A — paste the full client_secret.json content as a single-line string.
# IMPORTANT: do NOT wrap the value in quotes — docker-compose .env files treat
# quotes as literal characters, not shell quoting.
#   Wrong : GOOGLE_OAUTH_CLIENT_SECRET_JSON='{"web":{...}}'
#   Correct: GOOGLE_OAUTH_CLIENT_SECRET_JSON={"web":{...}}
GOOGLE_OAUTH_CLIENT_SECRET_JSON={"web":{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}}

# Option B — path to the client_secret.json file mounted into the container.
# docker-compose mounts ./secret/ → /secrets/ (read-only).
# Place your file at: ./secret/client_secret.json
# Then uncomment the line below and leave Option A empty.
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/secrets/client_secret.json

# ─── Server Base URL ──────────────────────────────────────────────────────────
# Public URL of this server — used to build the OAuth2 redirect URI and MCP
# metadata endpoints. Must match exactly what is registered in Google Cloud
# Console as an Authorized redirect URI.
#
# The redirect URI to register in Google Cloud Console:
#   <SERVER_BASE_URL>/google/callback
#
# Examples:
#   Production : SERVER_BASE_URL=https://your-domain.com
#   Local test : SERVER_BASE_URL=http://localhost:8347
SERVER_BASE_URL=https://your-domain.com

# ─── Server (HTTP transport only) ─────────────────────────────────────────────
SERVER_PORT=8347
SERVER_HOST=0.0.0.0

# ─── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
